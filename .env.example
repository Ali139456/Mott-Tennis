# Copy to .env.local and fill in the anon key from:
# Dashboard → Project Settings → API → Project API keys → anon (public)

NEXT_PUBLIC_SUPABASE_URL=https://bkxrrjmjldsgwwqxqzpp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stripe — https://dashboard.stripe.com/apikeys (use test keys locally; live keys in production only)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Products → each subscription Price; copy Price ID (price_...)
# Dashboard → Product → Pricing → copy price_... (not prod_...)
# Checkout mode follows the price: recurring → subscription, one-time → payment.
STRIPE_PRICE_FOUNDATION=
STRIPE_PRICE_PERFORMANCE=
STRIPE_PRICE_ELITE=
# Optional: canonical site URL for Stripe redirects if host headers are wrong locally
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — https://resend.com/api-keys
RESEND_API_KEY=
# Production: an address on your verified domain (e.g. Blake Mott Tennis Advisory <noreply@blakemott.com>).
# onboarding@resend.dev only works for limited test recipients — use your domain on Vercel.
RESEND_FROM_EMAIL=Blake Mott Tennis Advisory <noreply@blakemott.com>
# Where contact form submissions are delivered (defaults to SITE.email if unset)
# CONTACT_TO_EMAIL=info@blakemott.com
